{
  "name": "@ud/e2e-desktop",
  "version": "0.0.0",
  "private": true,
  "description": "End-to-end WebDriver tests for the Universal Downloader Tauri desktop app (driven by tauri-driver).",
  "scripts": {
    "test": "wdio run ./wdio.conf.ts",
    "test:windows": "cross-env TAURI_PLATFORM=windows wdio run ./wdio.conf.ts",
    "test:linux": "cross-env TAURI_PLATFORM=linux wdio run ./wdio.conf.ts"
  },
  "devDependencies": {
    "webdriverio": "^8.39.0",
    "@wdio/cli": "^8.39.0",
    "@wdio/local-runner": "^8.39.0",
    "@wdio/mocha-framework": "^8.39.0",
    "@wdio/spec-reporter": "^8.39.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.30",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
