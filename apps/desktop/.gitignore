# Build artifacts
target/
gen/
dist/

# Deps
node_modules/

# Sidecar binaries (fetched by J1.8 script)
src-tauri/binaries/

# Generated icons (regenerate via `tauri icon`).
# The bundle icons referenced by tauri.conf.json are checked in so CI can
# build without a source art pipeline; other generated sizes are ignored.
src-tauri/icons/*.png
src-tauri/icons/*.ico
src-tauri/icons/*.icns
!src-tauri/icons/32x32.png
!src-tauri/icons/128x128.png
!src-tauri/icons/128x128@2x.png
!src-tauri/icons/icon.png
!src-tauri/icons/icon.ico
!src-tauri/icons/icon.icns
!src-tauri/icons/README.md

# Misc
.DS_Store
*.log
.turbo/
