{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Universal Downloader",
  "version": "0.1.0",
  "identifier": "com.ct4nk3r.universaldownloader",
  "build": {
    "beforeDevCommand": "pnpm web:dev",
    "beforeBuildCommand": "pnpm web:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Universal Downloader by CT4nk3r",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data:; media-src 'self' asset: https: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https: http://localhost:* ws://localhost:*; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "app", "dmg", "deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 CT4nk3r",
    "category": "Utility",
    "shortDescription": "yt-dlp + ffmpeg downloader",
    "longDescription": "Universal Downloader by CT4nk3r — a desktop frontend for yt-dlp and ffmpeg with a unified job queue.",
    "externalBin": ["binaries/yt-dlp", "binaries/ffmpeg"],
    "resources": []
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["universal-downloader"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/CT4nk3r/universal-downloader/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
