{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "noEmit": true,
    "allowImportingTsExtensions": false
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "src-tauri/target", "src-tauri/gen"]
}
