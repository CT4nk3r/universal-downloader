{
  "name": "@universal-downloader/api-client",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./hooks": "./src/hooks.ts"
  },
  "scripts": {
    "codegen": "openapi-typescript ../shared-types/openapi.yaml -o src/generated/schema.ts",
    "lint": "echo \"(no-op)\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "echo \"(types only)\"",
    "clean": "rimraf src/generated .turbo"
  },
  "dependencies": {
    "@universal-downloader/shared-types": "workspace:*",
    "openapi-fetch": "^0.13.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@types/react": "^19.2.14",
    "openapi-typescript": "^7.4.1",
    "react": "^19.2.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.9"
  }
}
